    <title>在您的cent OS上运行一辆小火车</title>
    <link href="http://zxczh.github.io/2022/09/17/%E5%9C%A8%E6%82%A8%E7%9A%84centOS%E4%B8%8A%E8%BF%90%E8%A1%8C%E4%B8%80%E8%BE%86%E5%B0%8F%E7%81%AB%E8%BD%A6/"/>
    <id>http://zxczh.github.io/2022/09/17/%E5%9C%A8%E6%82%A8%E7%9A%84centOS%E4%B8%8A%E8%BF%90%E8%A1%8C%E4%B8%80%E8%BE%86%E5%B0%8F%E7%81%AB%E8%BD%A6/</id>
    <published>2022-09-16T16:00:00.000Z</published>
